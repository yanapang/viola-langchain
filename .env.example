# Wiki
WIKI_DIR=./wiki

# Provider selection: ollama | huggingface | openai | cursor
LLM_PROVIDER=ollama
# Provider selection: ollama | huggingface
EMBED_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
# Chat model (generates answers). Light: qwen2.5:7b (~5GB). Heavy: qwen3.6:27b
OLLAMA_LLM_MODEL=qwen2.5:7b
# Embedding model (retrieval). Use bge-m3 for Korean/multilingual wikis.
OLLAMA_EMBED_MODEL=bge-m3

# Response language for generated answers (ko | en)
RESPONSE_LANGUAGE=ko

# Legacy aliases (still supported)
# LLM_MODEL=llama3
# EMBED_MODEL=nomic-embed-text

# Hugging Face
# HUGGINGFACEHUB_API_TOKEN=hf_...
# HF_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# HF_EMBED_MODEL=BAAI/bge-m3

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_LLM_MODEL=gpt-4o-mini

# Cursor Agent API
# CURSOR_API_KEY=cursor_...
# CURSOR_MODEL=composer-2.5
